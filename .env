# ── Temel ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=dev-secret-change-in-production
DB_PATH=./nur_tasbih.db

# ── URL'ler ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# ── İyzico ────────────────────────────────────────────────────────────────
# merchant.iyzico.com'dan alırsın — bireysel başvuru kabul edilir
# Test ortamı (sandbox):
IYZICO_API_KEY=sandbox-api-key
IYZICO_SECRET_KEY=sandbox-secret-key
IYZICO_URI=https://sandbox-api.iyzipay.com
# Production'a geçince:
# IYZICO_API_KEY=gerçek-api-key
# IYZICO_SECRET_KEY=gerçek-secret-key
# IYZICO_URI=https://api.iyzipay.com
